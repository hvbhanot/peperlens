// PaperLens database schema
// Postgres on Railway. Run `prisma db push` on start (see package.json).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  // Ollama API key, AES-256-GCM encrypted at rest. Null until set in Settings.
  ollamaKeyEnc String?
  // Per-user Ollama preferences.
  ollamaModel  String   @default("gpt-oss:120b-cloud")
  ollamaHost   String   @default("https://ollama.com")
  papers       Paper[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Paper {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  fileName  String
  // Raw PDF bytes (stored as Postgres bytea). Capped by MAX_PDF_MB on upload.
  data      Bytes
  size      Int
  pages     Int      @default(0)
  level     String?
  // AI-generated structured metadata (cached).
  tags      String[] @default([])
  field     String?
  method    String?
  year      Int?
  // Pre-extracted text so we can re-query without re-parsing the PDF.
  textCache String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  analyses  Analysis[]
  notes     Note[]
  chatLogs  ChatLog[]
  flashcards Flashcard[]

  @@index([userId])
}

model Analysis {
  id        String   @id @default(cuid())
  paperId   String
  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  which     String
  // For "summary_mode" the sub-mode lives in opts.
  opts      String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([paperId, which, opts])
  @@index([paperId])
}

model Note {
  id        String   @id @default(cuid())
  paperId   String
  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  body      String
  // Optional page number the note was anchored to.
  page      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paperId])
}

model ChatLog {
  id        String   @id @default(cuid())
  paperId   String
  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([paperId, createdAt])
}

model Flashcard {
  id        String   @id @default(cuid())
  paperId   String
  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  // 0..1 for spaced-repetition (SRS) scheduling. 0 = unseen, 1 = mastered.
  mastery   Float    @default(0)
  lastSeen  DateTime?
  createdAt DateTime @default(now())

  @@index([paperId])
}
