# --- Database (Railway provides this automatically when you add Postgres) ---
DATABASE_URL="postgresql://user:password@localhost:5432/paperlens?schema=public"

# --- Auth: secret used to sign session JWTs (32+ random bytes) ---
# Generate with: npm run keygen
AUTH_SECRET="replace-with-a-long-random-string"

# --- Encryption: 32-byte key (64 hex chars) used to AES-256-GCM the Ollama key ---
# Generate with: npm run keygen
ENCRYPTION_KEY="replace-with-64-hex-characters"

# --- Optional: max PDF upload size in MB (default 8) ---
MAX_PDF_MB="8"
